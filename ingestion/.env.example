# Shopify custom app (Settings > Apps and sales channels > Develop apps)
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-10

# Snowflake service account used by the pipeline at runtime
# (separate from the admin credentials Terraform uses to provision infra)
SNOWFLAKE_ACCOUNT=xxxxx-xxxxx
SNOWFLAKE_USER=SHOPIFY_PIPELINE_SVC
SNOWFLAKE_PASSWORD=
# Alternative to password auth: path to a PEM-encoded private key (key-pair auth)
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_WAREHOUSE=SHOPIFY_WH
SNOWFLAKE_DATABASE=SHOPIFY_DATA
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=SHOPIFY_LOADER_ROLE
