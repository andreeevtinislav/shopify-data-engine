# Note: this file is sourced directly via `set -a && source .env && set +a`
# (dbt doesn't auto-load .env like ingestion/'s Python code does), so quote
# any value containing spaces (e.g. a path under "Creative Cloud Files").
SNOWFLAKE_ACCOUNT=xxxxx-xxxxx
SNOWFLAKE_USER=DBT_TRANSFORM_SVC
SNOWFLAKE_ROLE=DBT_TRANSFORM_ROLE
SNOWFLAKE_PRIVATE_KEY_PATH="./secrets/dbt_transform_key.p8"
SNOWFLAKE_DATABASE=SHOPIFY_DATA
SNOWFLAKE_WAREHOUSE=SHOPIFY_WH
SNOWFLAKE_SCHEMA=STAGING
